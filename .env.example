# ─── LA DIOSA — configuration container ────────────────────────────────────
# Copiez ce fichier en .env à côté du docker-compose.yml puis renseignez
# chmod 600 .env

# Domaine public du site (utilisé pour les liens RSS, sitemap, OG, CORS)
PUBLIC_ORIGIN=https://ladiosa.fr

# Origines autorisées pour les appels /api/* (CSV)
ALLOWED_ORIGINS=https://ladiosa.fr

# Compte GitHub/organisation propriétaire de l'image ghcr.io (minuscule)
GHCR_OWNER=infinition

# Mot de passe administrateur INITIAL (min. 12 caractères).
# Laissez vide si vous préférez utiliser /api/auth/setup au premier lancement.
# Une fois le hash écrit dans config.json, cette variable peut être retirée.
ADMIN_PASSWORD=

# Token unique exigé pour appeler /api/auth/setup (option anti-squat).
# Générez une chaîne aléatoire : openssl rand -hex 32
SETUP_TOKEN=
